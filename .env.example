# ═══════════════════════════════════════════════════════════════════════════════
# 🧅 SISTEMA ONION - CONFIGURAÇÕES DE AMBIENTE
# ═══════════════════════════════════════════════════════════════════════════════
# Copie para .env e preencha os valores necessários
# ⚠️ NUNCA commite o arquivo .env com dados sensíveis!
#
# Documentação: docs/onion/getting-started.md
# Setup guiado: /meta/setup-integration
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# 🎯 GERENCIADOR DE TAREFAS (Principal)
# ═══════════════════════════════════════════════════════════════════════════════
# Provedor ativo para /product/task, /engineer/start, etc.
# Opções: clickup | asana | jira | linear | none
TASK_MANAGER_PROVIDER=clickup


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 CLICKUP (se TASK_MANAGER_PROVIDER=clickup)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: ClickUp > Settings > Apps > API Token
CLICKUP_API_TOKEN=

# Workspace ID - detectado automaticamente se não informado
# Encontre em: URL do ClickUp (https://app.clickup.com/XXXXXXXX/...)
CLICKUP_WORKSPACE_ID=

# Lista padrão para novas tasks (opcional)
# Encontre em: URL da lista (https://app.clickup.com/.../li/XXXXXXXX)
CLICKUP_DEFAULT_LIST_ID=


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 ASANA (se TASK_MANAGER_PROVIDER=asana)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: Asana > My Settings > Apps > Developer Apps > Personal Access Token
# ASANA_ACCESS_TOKEN=

# Workspace e projeto padrão
# ASANA_WORKSPACE_ID=
# ASANA_DEFAULT_PROJECT_ID=


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 JIRA (se TASK_MANAGER_PROVIDER=jira)
# ═══════════════════════════════════════════════════════════════════════════════
# Host: seu-dominio.atlassian.net
# JIRA_HOST=

# Email e API Token: Atlassian Account > Security > API Tokens
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# Projeto padrão (ex: PROJ)
# JIRA_PROJECT_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 LINEAR (se TASK_MANAGER_PROVIDER=linear)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: Linear > Settings > API > Personal API Keys
# LINEAR_API_KEY=

# Team ID padrão
# LINEAR_TEAM_ID=


# ═══════════════════════════════════════════════════════════════════════════════
# 🐙 GITHUB (Automações Git e PRs)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: GitHub > Settings > Developer settings > Personal access tokens
# Escopos necessários: repo, workflow
GITHUB_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════════
# 🎨 GAMMA.APP (Apresentações com IA)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: gamma.app > Settings > API
GAMMA_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# 🐘 POSTGRESQL (Banco de Dados)
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=


# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 CONFIGURAÇÕES AVANÇADAS (Opcional)
# ═══════════════════════════════════════════════════════════════════════════════
# Nível de log: debug | info | warn | error
# LOG_LEVEL=info

# Timeout para chamadas de API (ms)
# API_TIMEOUT=30000

# Habilitar cache de contexto
# CONTEXT_CACHE_ENABLED=true
