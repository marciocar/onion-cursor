# ===========================================
# Sistema Onion - Configurações de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# IMPORTANTE: Nunca commite o arquivo .env!

# -------------------------------------------
# ClickUp MCP (Gestão de Tarefas)
# -------------------------------------------
# Obtenha em: Settings > Apps > API Token
CLICKUP_API_TOKEN=
# Opcional - detectado automaticamente se não fornecido
CLICKUP_WORKSPACE_ID=

# -------------------------------------------
# Gamma.App API (Apresentações com IA)
# -------------------------------------------
# Obtenha em: gamma.app/settings/api
GAMMA_API_KEY=

# -------------------------------------------
# PostgreSQL (Banco de Dados)
# -------------------------------------------
# Configure conforme seu ambiente
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# -------------------------------------------
# GitHub (opcional - para automações Git)
# -------------------------------------------
GITHUB_TOKEN=
